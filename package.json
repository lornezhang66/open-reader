{
  "name": "open-reader",
  "version": "1.0.7",
  "description": "Turn Markdown notes into private, natural offline speech.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "tts",
    "text-to-speech",
    "local-tts",
    "offline-tts",
    "markdown-reader",
    "note-reader",
    "ttsctl"
  ],
  "author": "zhangxiaolong",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.29",
    "esbuild": "^0.25.5",
    "obsidian": "^1.8.7",
    "typescript": "^5.8.3"
  }
}
