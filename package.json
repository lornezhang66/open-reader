{
  "name": "open-reader",
  "version": "1.0.4",
  "description": "Obsidian local TTS plugin for reading Markdown notes aloud with an offline text-to-speech CLI.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "tts",
    "text-to-speech",
    "local-tts",
    "offline-tts",
    "markdown-reader",
    "note-reader",
    "ttsctl"
  ],
  "author": "zhangxiaolong",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.29",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.25.5",
    "obsidian": "^1.8.7",
    "typescript": "^5.8.3"
  }
}
