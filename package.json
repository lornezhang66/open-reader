{
  "name": "cloud-tts-reader",
  "version": "1.0.1",
  "description": "Read Obsidian Markdown notes aloud with a local TTS CLI.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "tts",
    "text-to-speech"
  ],
  "author": "zhangxiaolong",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.29",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.25.5",
    "obsidian": "^1.8.7",
    "typescript": "^5.8.3"
  }
}
